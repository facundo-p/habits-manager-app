{
  "expo": {
    "name": "CozyHabit",
    "slug": "cozy-habit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "androidStatusBar": {
      "barStyle": "dark-content",
      "translucent": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffbeb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.facupich.cozyhabit"
    },
    "android": {
      "package": "com.facupich.cozyhabit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffbeb"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-sqlite",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.536551592924-sn9roip13db3ulhat4k85skvuo9s29ei",
          "webClientId": "536551592924-t3bihg007iv89vlb4025fmovepn592kd.apps.googleusercontent.com",
          "androidClientId": "536551592924-sn9roip13db3ulhat4k85skvuo9s29ei.apps.googleusercontent.com"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "153f52bd-3be7-4b9b-8400-903e38d80162"
      }
    }
  }
}
